# Database driver: mongo | supabase
# Default for local MVP is mongo (no auth, localhost).
DB_DRIVER=mongo

# ----- MongoDB (local, no auth) -----
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=portal_noiva

# ----- Supabase (filled later when migrating to prod) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- AWS S3 (media bucket) -----
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# ----- Geocoding -----
NOMINATIM_USER_AGENT=portal-noiva/1.0 (contato@dominio.org)

# ----- App -----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DEFAULT_LOCALE=pt-BR
MASTER_ADMIN_EMAILS=jsdevti@gmail.com

# ----- Auth (Auth.js v5) -----
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (Cloud Console -> APIs & Services -> Credentials -> OAuth client ID)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
